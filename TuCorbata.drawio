        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;%%{init: {\n  \&quot;theme\&quot;: \&quot;base\&quot;,\n  \&quot;themeVariables\&quot;: {\n    \&quot;background\&quot;: \&quot;#ffffff\&quot;,\n    \&quot;primaryTextColor\&quot;: \&quot;#1f2937\&quot;,\n    \&quot;lineColor\&quot;: \&quot;#64748b\&quot;,\n    \&quot;fontFamily\&quot;: \&quot;Arial\&quot;\n  }\n}}%%\n\nerDiagram\n    direction LR\n\n    USUARIO ||--o{ DIRECCION : tiene\n    USUARIO ||--o{ PEDIDO : realiza\n    DIRECCION ||--o{ PEDIDO : se_utiliza_en\n\n    PEDIDO ||--|{ DETALLEPEDIDO : contiene\n    CORBATA ||--o{ DETALLEPEDIDO : aparece_en\n\n    MARCA ||--o{ CORBATA : clasifica\n    COLOR ||--o{ CORBATA : clasifica\n    TALLA ||--o{ CORBATA : clasifica\n    MATERIAL ||--o{ CORBATA : clasifica\n\n    USUARIO {\n        int id_usuario PK\n        string nombre\n        string apellidos\n        string email\n        string password\n        string telefono\n        date fecha_registro\n        boolean activo\n    }\n\n    DIRECCION {\n        int id_direccion PK\n        int id_usuario FK\n        string nombre_destinatario\n        string calle\n        string numero\n        string piso\n        string codigo_postal\n        string localidad\n        string provincia\n        string pais\n        boolean principal\n    }\n\n    PEDIDO {\n        int id_pedido PK\n        int id_usuario FK\n        int id_direccion FK\n        datetime fecha_pedido\n        string estado\n        decimal total\n    }\n\n    DETALLEPEDIDO {\n        int id_detalle PK\n        int id_pedido FK\n        int id_corbata FK\n        int cantidad\n        decimal precio_unitario\n        decimal subtotal\n    }\n\n    CORBATA {\n        int id_corbata PK\n        int id_talla FK\n        int id_color FK\n        int id_material FK\n        int id_marca FK\n        string nombre\n        string descripcion\n        decimal precio\n        int stock\n        string imagen\n        boolean activa\n    }\n\n    MARCA {\n        int id_marca PK\n        string nombre\n        string descripcion\n    }\n\n    COLOR {\n        int id_color PK\n        string nombre\n        string codigo_hex\n    }\n\n    TALLA {\n        int id_talla PK\n        string nombre\n        decimal longitud_cm\n        string descripcion\n    }\n\n    MATERIAL {\n        int id_material PK\n        string nombre\n        string descripcion\n    }\n\n    classDef gestion fill:#eaf3ff,stroke:#4a78a8,color:#102a43,stroke-width:2px;\n    classDef detalle fill:#f3e8ff,stroke:#8b5cf6,color:#3b0764,stroke-width:2px;\n    classDef producto fill:#fff1e6,stroke:#f97316,color:#431407,stroke-width:2px;\n    classDef clasificacion fill:#eaf8ea,stroke:#22c55e,color:#052e16,stroke-width:2px;\n\n    class USUARIO,DIRECCION,PEDIDO gestion;\n    class DETALLEPEDIDO detalle;\n    class CORBATA producto;\n    class MARCA,COLOR,TALLA,MATERIAL clasificacion;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="dHRLT5Lxco373OUakoeV-957">
